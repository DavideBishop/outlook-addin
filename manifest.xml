<?xml version="1.0" encoding="UTF-8"?>
<OfficeApp xmlns="http://schemas.microsoft.com/office/appforoffice/1.1"
  xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
  xmlns:bt="http://schemas.microsoft.com/office/officeappbasictypes/1.0"
  xsi:type="MailApp">

  <Id>c7f3a921-4d8b-4e6f-b123-9a0e5d7c2f81</Id>
  <Version>1.0.0.0</Version>
  <ProviderName>Bishop Fraser</ProviderName>
  <DefaultLocale>en-US</DefaultLocale>
  <DisplayName DefaultValue="Client Code Reminder"/>
  <Description DefaultValue="Reminds users to add a client code prefix before sending email."/>
  <IconUrl DefaultValue="https://placehold.co/64x64.png"/>
  <HighResolutionIconUrl DefaultValue="https://placehold.co/128x128.png"/>
  <SupportUrl DefaultValue="https://davidebishop.github.io/outlook-addin/"/>

  <AppDomains>
    <AppDomain>https://davidebishop.github.io</AppDomain>
  </AppDomains>

  <Hosts>
    <Host Name="Mailbox"/>
  </Hosts>

  <Requirements>
    <Sets>
      <Set Name="Mailbox" MinVersion="1.3"/>
    </Sets>
  </Requirements>

  <FormSettings>
    <Form xsi:type="ItemEdit">
      <DesktopSettings>
        <SourceLocation DefaultValue="https://davidebishop.github.io/outlook-addin/commands.html"/>
      </DesktopSettings>
    </Form>
  </FormSettings>

  <Permissions>ReadWriteItem</Permissions>

  <Rule xsi:type="RuleCollection" Mode="Or">
    <Rule xsi:type="ItemIs" ItemType="Message" FormType="Edit"/>
  </Rule>

  <DisableEntityHighlighting>false</DisableEntityHighlighting>

  <VersionOverrides xmlns="http://schemas.microsoft.com/office/mailappversionoverrides" xsi:type="VersionOverridesV1_0">
    <Requirements>
      <bt:Sets DefaultMinVersion="1.3">
        <bt:Set Name="Mailbox"/>
      </bt:Sets>
    </Requirements>
    <Hosts>
      <Host xsi:type="MailHost">
        <DesktopFormFactor>
          <FunctionFile resid="Commands.Url"/>
          <ExtensionPoint xsi:type="Events">
            <Event Type="ItemSend" FunctionExecution="synchronous" FunctionName="onItemSend"/>
          </ExtensionPoint>
        </DesktopFormFactor>
      </Host>
    </Hosts>
    <Resources>
      <bt:Images>
        <bt:Image id="Icon.16x16" DefaultValue="https://placehold.co/16x16.png"/>
        <bt:Image id="Icon.32x32" DefaultValue="https://placehold.co/32x32.png"/>
        <bt:Image id="Icon.80x80" DefaultValue="https://placehold.co/80x80.png"/>
      </bt:Images>
      <bt:Urls>
        <bt:Url id="Commands.Url" DefaultValue="https://davidebishop.github.io/outlook-addin/commands.html"/>
      </bt:Urls>
      <bt:ShortStrings>
        <bt:String id="GroupLabel" DefaultValue="Client Code"/>
      </bt:ShortStrings>
      <bt:LongStrings>
        <bt:String id="GroupLabel.Tooltip" DefaultValue="Client Code Reminder"/>
      </bt:LongStrings>
    </Resources>
  </VersionOverrides>
</OfficeApp>
